{
  "extends": "../../tsconfig.json",

  "compilerOptions": {
    "target": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],

    "module": "esnext",
    "moduleResolution": "node",

    "rootDir": ".",

    "strict": true,
    "noImplicitAny": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "skipLibCheck": true,

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": ["**/*.ts", "**/*.vue"]
}
