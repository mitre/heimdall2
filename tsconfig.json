{
  "compilerOptions": {
    "target": "ES2021",

    "module": "commonjs",
    "moduleResolution": "node",

    "noImplicitAny": true,
    "useUnknownInCatchVariables": false,

    "declaration": true,
    "sourceMap": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": [
    "types/**/*.d.ts"
  ],
  "exclude": [
    "**/node_modules"
  ]
}
