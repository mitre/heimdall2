# Heimdall backend runtime settings
# Values are prompted during first-time package install.

NODE_ENV=production
PORT=3000

# PostgreSQL connection
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USERNAME=heimdall
DATABASE_PASSWORD=
DATABASE_NAME=heimdall-server-production

# Authentication settings
# Auto-generated during interactive package install if left blank.
JWT_SECRET=
JWT_EXPIRE_TIME=1d

# Generate with: openssl rand -hex 33
# Leave blank to disable API keys.
API_KEY_SECRET=

# Initial admin user defaults used during db:seed:all
ADMIN_EMAIL=admin@heimdall.local
# ADMIN_PASSWORD=change-me
